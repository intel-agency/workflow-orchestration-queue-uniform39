# Environment variables for workflow-orchestration-queue
# Copy this file to .env and fill in the values before running locally.
# NEVER commit .env to the repository.

# GitHub authentication
GITHUB_TOKEN=YOUR_GITHUB_TOKEN_HERE

# ZhipuAI GLM model access (required for opencode worker)
ZHIPU_API_KEY=your_zhipu_api_key_here

# GitHub App webhook secret (HMAC SHA-256 verification)
WEBHOOK_SECRET=your_webhook_secret_here

# Sentinel configuration
SENTINEL_ID=sentinel-01
POLL_INTERVAL_SECONDS=60
TASK_TIMEOUT_MINUTES=120
HEARTBEAT_INTERVAL_MINUTES=5

# opencode server
OPENCODE_SERVER_HOSTNAME=127.0.0.1
OPENCODE_SERVER_PORT=4096
OPENCODE_SERVER_USERNAME=
OPENCODE_SERVER_PASSWORD=

# Workspace path for shell bridge volume mount
WORKSPACE_PATH=.
